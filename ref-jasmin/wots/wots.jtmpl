inline fn __wots_pk_from_sig(
    reg ptr u8[XMSS_WOTS_LEN * XMSS_N] pk,
    #spill_to_mmx reg u64 sig_ptr,
    reg ptr u8[XMSS_N] msg,
    #spill_to_mmx reg ptr u8[XMSS_N] pub_seed,
    reg ptr u32[8] addr,
    #msf reg u64 ms
) -> reg ptr u8[XMSS_WOTS_LEN * XMSS_N], reg ptr u32[8], #msf reg u64
{
    stack u8[XMSS_N] buf;
    stack u32[XMSS_WOTS_LEN] lengths;

    reg u32 chain start steps;
    reg u64 t;
    inline int i j;

    reg ptr u8[XMSS_N] pk_ptr;

    () = #spill(pub_seed, sig_ptr);

    // chain_lengths(params, lengths, msg);
    // lengths = __chain_lengths_(lengths, msg);

    for i=0 to XMSS_WOTS_LEN {
        // set_chain_addr(addr, i);
        chain = i;
        addr = __set_chain_addr(addr, chain);

        // gen_chain(params, pk + i * params->n, sig + i * params->n, lengths[i], params->wots_w - 1 - lengths[i], pub_seed, addr);
        () = #unspill(pub_seed, sig_ptr);
        start = lengths[i]; start = #protect_32(start, ms);
        steps = XMSS_WOTS_W - 1; steps -= lengths[i]; steps = #protect_32(steps, ms);
        t = sig_ptr; t += i*XMSS_N;
        pk[i*XMSS_N : XMSS_N], addr, ms = __gen_chain_(pk[i*XMSS_N : XMSS_N], t, start, steps, pub_seed, addr, ms);
    }

    return pk, addr, ms;
}

fn _wots_pk_from_sig(
    reg ptr u8[XMSS_WOTS_LEN * XMSS_N] pk,
    reg u64 sig_ptr,
    reg ptr u8[XMSS_N] msg,
    reg ptr u8[XMSS_N] pub_seed,
    reg ptr u32[8] addr,
    #msf reg u64 ms
) -> reg ptr u8[XMSS_WOTS_LEN * XMSS_N], reg ptr u32[8], #msf reg u64
{
    pk, addr, ms = __wots_pk_from_sig(pk, sig_ptr, msg, pub_seed, addr, ms);
    return pk, addr, ms;
}

inline fn __wots_pk_from_sig_(
    reg ptr u8[XMSS_WOTS_LEN * XMSS_N] pk,
    reg u64 sig_ptr,
    reg ptr u8[XMSS_N] msg,
    reg ptr u8[XMSS_N] pub_seed,
    reg ptr u32[8] addr,
    #msf reg u64 ms
) -> reg ptr u8[XMSS_WOTS_LEN * XMSS_N], reg ptr u32[8], #msf reg u64
{
    pk = pk;
    sig_ptr = sig_ptr;
    msg = msg;
    pub_seed = pub_seed;
    addr = addr;

    pk, addr, ms = __wots_pk_from_sig(pk, sig_ptr, msg, pub_seed, addr, ms);

    pk = pk;
    addr = addr;

    return pk, addr, ms;
}
