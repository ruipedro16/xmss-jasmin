inline fn __wots_sign(
    reg ptr u8[XMSS_WOTS_LEN * XMSS_N] sig,
    reg ptr u8[XMSS_N] msg,
    reg ptr u8[XMSS_N] seed,
    reg ptr u8[XMSS_N] pub_seed,
    reg ptr u32[8] addr,
    #msf reg u64 ms
) -> reg ptr u8[XMSS_WOTS_LEN * XMSS_N], reg ptr u32[8], #msf reg u64
{
    stack u8[XMSS_N] buf;
    stack u32[XMSS_WOTS_LEN] lengths;

    reg u32 chain t;
    inline int i j;

    reg ptr u8[XMSS_N] pk_ptr;

    () = #spill(pub_seed);
    // chain_lengths(params, lengths, msg);
    lengths, ms = __chain_lengths_(lengths, msg, ms);

    // expand_seed(params, sig, seed, pub_seed, addr);
    // sig, addr, ms = __expand_seed_(sig, seed, pub_seed, addr, ms);
    // FIXME: reg alloc fails

    for i = 0 to XMSS_WOTS_LEN {
        // set_chain_addr(addr, i);
        chain = i;
        addr = __set_chain_addr(addr, chain);

        // gen_chain(params, sig + i * params->n, sig + i * params->n, 0, lengths[i], pub_seed, addr);
        () = #unspill(pub_seed);
        for j=0 to XMSS_N { buf[j] = sig[i*XMSS_N + j]; }
        t = lengths[i]; t = #protect_32(t, ms);
        // sig[i*XMSS_N : XMSS_N], addr, ms = __gen_chain_inplace(sig[i*XMSS_N : XMSS_N], buf, 0, t, pub_seed, addr, ms);
        // FIXME: reg alloc fails
    }

    return sig, addr, ms;
}


fn _wots_sign(
    reg ptr u8[XMSS_WOTS_LEN * XMSS_N] sig,
    reg ptr u8[XMSS_N] msg,
    reg ptr u8[XMSS_N] seed,
    reg ptr u8[XMSS_N] pub_seed,
    reg ptr u32[8] addr,
    #msf reg u64 ms
) -> reg ptr u8[XMSS_WOTS_LEN * XMSS_N], reg ptr u32[8], #msf reg u64
{
    sig, addr, ms = __wots_sign(sig, msg, seed, pub_seed, addr, ms);
    return sig, addr, ms;
}

inline fn __wots_sign_(
    reg ptr u8[XMSS_WOTS_LEN * XMSS_N] sig,
    reg ptr u8[XMSS_N] msg,
    reg ptr u8[XMSS_N] seed,
    reg ptr u8[XMSS_N] pub_seed,
    reg ptr u32[8] addr,
    #msf reg u64 ms
) -> reg ptr u8[XMSS_WOTS_LEN * XMSS_N], reg ptr u32[8], #msf reg u64
{
    sig = sig;
    msg = msg;
    seed = seed;
    pub_seed = pub_seed;
    addr = addr;

    sig, addr, ms = _wots_sign(sig, msg, seed, pub_seed, addr, ms);

    sig = sig;
    addr = addr;

    return sig, addr, ms;
}

