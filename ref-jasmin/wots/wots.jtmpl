inline fn __wots_pkgen(
    reg ptr u8[XMSS_WOTS_LEN * XMSS_N] pk,
    reg ptr u8[XMSS_N] seed,
    reg ptr u8[XMSS_N] pub_seed,
    reg ptr u32[8] addr,
    #msf reg u64 ms
) -> reg ptr u8[XMSS_WOTS_LEN * XMSS_N], reg ptr u32[8], #msf reg u64
{
    stack u8[XMSS_N] buf;
    reg u32 chain;
    inline int i j;

    stack ptr u8[XMSS_WOTS_LEN * XMSS_N] s_pk;
    reg ptr u8[XMSS_N] t;

    () = #spill(pub_seed);

    // expand_seed(params, pk, seed, pub_seed, addr);
    pk, addr, ms = __expand_seed(pk, seed, pub_seed, addr, ms);
    
    for i = 0 to XMSS_WOTS_LEN {
        // set_chain_addr(addr, i);
        chain = i;
        addr = __set_chain_addr(addr, chain);

        () = #unspill(pub_seed);
        for j=0 to XMSS_N { buf[j] = pk[i*XMSS_N + j]; }

        // TODO: FIXME:
        // t = pk[i*XMSS_N : XMSS_N];
        // s_pk = pk; // spill
        // t, addr, ms = (t, buf, 0, XMSS_WOTS_W - 1, pub_seed, addr, ms);
        // t = #protect_ptr(t, ms);
        // s_pk[i*XMSS_N : XMSS_N] = t;
        // pk = s_pk; // unspill
        // pk = #protect_ptr(pk, ms);
        
    }

    return pk, addr, ms;
}

fn _wots_pkgen(
    reg ptr u8[XMSS_WOTS_LEN * XMSS_N] pk,
    reg ptr u8[XMSS_N] seed,
    reg ptr u8[XMSS_N] pub_seed,
    reg ptr u32[8] addr,
    #msf reg u64 ms
) -> reg ptr u8[XMSS_WOTS_LEN * XMSS_N], reg ptr u32[8], #msf reg u64
{
    pk, addr, ms = __wots_pkgen(pk, seed, pub_seed, addr, ms);
    return pk, addr, ms;
}

inline fn __wots_pkgen_(
    reg ptr u8[XMSS_WOTS_LEN * XMSS_N] pk,
    reg ptr u8[XMSS_N] seed,
    reg ptr u8[XMSS_N] pub_seed,
    reg ptr u32[8] addr,
    #msf reg u64 ms
) -> reg ptr u8[XMSS_WOTS_LEN * XMSS_N], reg ptr u32[8], #msf reg u64
{
    pk = pk;
    seed = seed;
    pub_seed = pub_seed;
    addr = addr;

    pk, addr, ms = _wots_pkgen(pk, seed, pub_seed, addr, ms);
    
    pk = pk;
    addr = addr;

    return pk, addr, ms;
}

